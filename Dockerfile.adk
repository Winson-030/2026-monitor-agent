FROM python:3.13-slim

WORKDIR /app

# Install system dependencies for ADK web UI and gcloud
RUN apt-get update && apt-get install -y --no-install-recommends \
    curl \
    gnupg \
    && rm -rf /var/lib/apt/lists/*

# Install Python dependencies
COPY requirements.txt requirements-adk.txt ./
RUN pip install --no-cache-dir -r requirements.txt -r requirements-adk.txt

# Copy application code
COPY . .

# Create non-root user
RUN adduser --disabled-password --gecos "" myuser && \
    chown -R myuser:myuser /app
USER myuser

ENV PATH="/home/myuser/.local/bin:$PATH"
ENV ADK_SERVE_WEB="true"

# Expose Cloud Run port
EXPOSE 8080

# Run ADK API server with web UI
CMD ["sh", "-c", "uvicorn main_adk:app --host 0.0.0.0 --port ${PORT:-8080}"]
